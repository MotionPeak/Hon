# Skip Puppeteer's bundled Chrome download during `npm install`.
#
# Why: it's 170 MB, and on Windows it's routinely quarantined by Defender
# mid-extract, leaving a half-installed folder that fails verification and
# blocks the entire install. Almost every machine already has Google Chrome
# installed system-wide; web.mjs auto-discovers it at launch and points
# Puppeteer at it via PUPPETEER_EXECUTABLE_PATH. If Chrome isn't installed,
# web.mjs prints a clear "install Chrome from google.com/chrome" message
# instead of the cryptic Puppeteer stack trace.
puppeteer_skip_download=true
