{
  "name": "hon-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local engine for Hon — scraping, storage, and on-device LLM.",
  "scripts": {
    "start": "node --import tsx src/server.ts",
    "dev": "node --import tsx --watch src/server.ts",
    "web": "./web.sh",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package"
  },
  "engines": {
    "node": ">=22.12"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.8.5",
    "israeli-bank-scrapers": "^6.7.4",
    "node-llama-cpp": "^3.18.1",
    "puppeteer": "^24.43.1",
    "snaptrade-typescript-sdk": "^9.0.200"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "patch-package": "^8.0.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
