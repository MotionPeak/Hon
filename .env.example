# Copy this file to `.env` and fill in HON_TOKEN before `docker compose up`.

# The bearer token that gates every API call — your only authentication.
# Make it long and random. Generate one with:
#   node -e "console.log(require('crypto').randomUUID())"
# Anyone with this token (and network access) can reach your finances, so
# keep Hon on a private network or VPN and treat this like a password.
HON_TOKEN=
